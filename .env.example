# 生产环境变量模板。复制为 .env 并填入真实值(.env 不进 Git)。

# Django
DEBUG=0
SECRET_KEY=请用 python -c "import secrets;print(secrets.token_urlsafe(50))" 生成
ALLOWED_HOSTS=dc.ezra76.com
CSRF_TRUSTED_ORIGINS=https://dc.ezra76.com

# PostgreSQL
POSTGRES_DB=dc
POSTGRES_USER=dc
POSTGRES_PASSWORD=请改成强密码
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis(Celery broker)
REDIS_URL=redis://redis:6379/0

# Let's Encrypt
CERTBOT_EMAIL=you@example.com
